{
	"name": "pl_bronze_cp_from_adls_to_blob",
	"properties": {
		"description": "This pipeline is used to copy a file from azure data lake to blob storage",
		"activities": [
			{
				"name": "copy_adl_blob",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"typeProperties": {
					"source": {
						"type": "DelimitedTextSource",
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "DelimitedTextReadSettings"
						}
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobStorageWriteSettings",
							"copyBehavior": "PreserveHierarchy"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".csv"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"name": "department_id",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "department_id",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "department_name",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "department_name",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "business_unit",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "business_unit",
									"type": "String",
									"physicalType": "String"
								}
							}
						],
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "ds_dp_src_csv_adls",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "ds_dp_tgt_csv_blob",
						"type": "DatasetReference"
					}
				]
			}
		],
		"annotations": [],
		"lastPublishTime": "2026-06-08T14:37:58Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}