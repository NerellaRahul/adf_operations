				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": "SELECT COUNT(*) AS file_count\nFROM ctl.file_manifest\nWHERE target_file_path='@{variables('v_target_file_path')}'\nAND status='Succeeded'",
