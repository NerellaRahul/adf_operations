						"status": {
							"value": "started",
							"type": "String"
						}
					}
				},
				"linkedServiceName": {
					"referenceName": "LS_AZSQL_CONTROL",
					"type": "LinkedServiceReference"
				}
			},
			{
				"name": "IF_Load_Type_Incremental",
				"description": "if the Load type is Incremental then uing this expression \n@equals(\ntoUpper(pipeline().parameters.p_load_type),\n'INCREMENTAL'\n)\nget Lookup_Get_HWM\nelse \nSET_HWM_FULL",
				"type": "IfCondition",
				"dependsOn": [
					{
						"activity": "SP_Table_Started",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "@equals(\ntoUpper(pipeline().parameters.p_load_type),\n'INCREMENTAL'\n)",
						"type": "Expression"
					},
					"ifFalseActivities": [
						{
							"name": "SET_HWM_FULL",
							"type": "SetVariable",
							"dependsOn": [],
							"policy": {
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"variableName": "v_hwm_value",
								"value": "@pipeline().parameters.p_lwm_value"
							}
						}
					],
					"ifTrueActivities": [
						{
							"name": "Lookup_get_HWM",
							"type": "Lookup",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "SqlServerSource",
									"sqlReaderQuery": "@concat(\n'SELECT MAX([',\npipeline().parameters.p_watermark_column,\n']) AS hwm_value\nFROM [',\npipeline().parameters.p_schema_name,\n'].[',\npipeline().parameters.p_table_name,\n']\nWHERE [',\npipeline().parameters.p_watermark_column,\n'] > ''',\npipeline().parameters.p_lwm_value,\n''''\n)",
									"queryTimeout": "02:00:00",
									"isolationLevel": "ReadCommitted",
									"partitionOption": "None"
								},
								"dataset": {
									"referenceName": "DS_SQLSERVER_DYNAMIC",
									"type": "DatasetReference",
									"parameters": {
										"p_schema_name": {
											"value": "@pipeline().parameters.p_schema_name",
											"type": "Expression"
										},
										"p_table_name": {
											"value": "@pipeline().parameters.p_table_name",
											"type": "Expression"
										}
									}
								}
							}
						},
						{
							"name": "SET_HWM_INCREMENTAL",
							"type": "SetVariable",
							"dependsOn": [
								{
									"activity": "Lookup_get_HWM",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"variableName": "v_hwm_value",
								"value": "@activity('Lookup_Get_HWM').output.firstRow.hwm_value"
							}
						}
					]
				}
			},
			{
				"name": "SET_FOLDER_PATH",
				"type": "SetVariable",
				"dependsOn": [
