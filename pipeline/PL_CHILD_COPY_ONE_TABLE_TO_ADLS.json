{
	"name": "PL_CHILD_COPY_ONE_TABLE_TO_ADLS",
	"properties": {
		"description": "table_run_log lo current table Started ani entry pettadam",
		"activities": [
			{
				"name": "SP_Table_Started",
				"type": "SqlServerStoredProcedure",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"storedProcedureName": "[ctl].[sp_upsert_table_log]",
					"storedProcedureParameters": {
						"batch_id": {
							"value": {
								"value": "@pipeline().parameters.p_batch_id",
								"type": "Expression"
							},
							"type": "String"
						},
						"table_id": {
							"value": {
								"value": "@int(pipeline().parameters.p_table_id)",
								"type": "Expression"
							},
							"type": "Int32"
						},
						"schema_name": {
							"value": {
								"value": "@pipeline().parameters.p_schema_name",
								"type": "Expression"
							},
							"type": "String"
						},
						"table_name": {
							"value": {
								"value": "@pipeline().parameters.p_table_name",
								"type": "Expression"
