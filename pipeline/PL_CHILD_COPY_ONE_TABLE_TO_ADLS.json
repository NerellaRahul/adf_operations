				"userProperties": [],
				"typeProperties": {
					"variableName": "v_folder_path",
					"value": "@concat(\npipeline().parameters.p_schema_name,\n'/',\npipeline().parameters.p_table_name,\n'/',\nformatDateTime(utcNow(),'yyyy/MM/dd')\n)"
				}
